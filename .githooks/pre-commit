#!/usr/bin/env bash
# Fast pre-commit gate: leak-guard + the cached `smoke:qc:fast` subset.
#
# Runs the centrally defined subset of `bun run smoke:qc` used during iteration.
# The full smoke:qc (includes build, feature-integration, schema-parity,
# check-deps) still runs in CI — this hook catches the usual class of
# regressions locally without slowing down contributor iteration.
#
# Bypass with `git commit --no-verify` only for WIP/experimental commits
# or confirmed false positives.

set -euo pipefail

echo "pre-commit: leak-guard"
bash .githooks/leak-guard.sh

echo "pre-commit: qc (cached subset of smoke:qc)"
bun run smoke:qc:fast

# The third-party license inventory is generated FROM bun.lock, so a dependency change that
# does not regenerate it commits artifacts that disagree with the lockfile. check:licenses is
# not in the fast subset, so nothing local catches that; it has reached main more than once and
# surfaced only in a later full smoke:qc. Gate it here, but only when a dependency manifest is
# actually staged, so ordinary commits pay nothing for it.
#
# Read into a variable rather than piping into grep: under `set -o pipefail` a matching `grep -q`
# can still fail the pipeline when it closes the pipe early and git takes SIGPIPE, which would
# silently skip the check on exactly the commits that need it.
staged_files=$(git diff --cached --name-only --diff-filter=ACMR)
if grep -qE '(^|/)(bun\.lock|package\.json)$' <<<"$staged_files"; then
	echo "pre-commit: check:licenses (dependency manifest staged)"
	bun run check:licenses
fi

echo "pre-commit: passed"
