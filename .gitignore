data/.seeded
data/*.bak
data/*.db
data/*.db-journal
data/*.db-shm
data/*.db-wal
data/*.db.lock
data/coordinator/
data/exports/
data/migration-history.json
data/run-logs/
data/uploads/
dist/
frontend/dist/

# logs/temp
*.bak
*.log
*.tmp
/tmp/
logs/
nul/

