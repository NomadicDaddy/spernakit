{
	"name": "spernakit-backend",
	"private": true,
	"author": "NomadicDaddy",
	"description": "Backend API for Spernakit v3",
	"dependencies": {
		"@elysiajs/swagger": "1.3.1",
		"@sinclair/typebox": "0.34.49",
		"@types/pg": "8.20.0",
		"drizzle-orm": "0.45.2",
		"elysia": "1.4.29",
		"jsonwebtoken": "9.0.3",
		"lru-cache": "11.5.1",
		"nodemailer": "9.0.1",
		"otpauth": "9.5.1",
		"pg": "8.22.0",
		"pino": "10.3.1",
		"pino-roll": "4.0.0",
		"spernakit-shared": "workspace:*",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@types/jsonwebtoken": "9.0.10",
		"@types/nodemailer": "8.0.1",
		"drizzle-kit": "0.31.10",
		"pino-pretty": "13.1.3",
		"typescript": "6.0.3",
		"only-allow": "1.2.2"
	},
	"engines": {
		"bun": ">=1.3.14",
		"node": ">=24.0.0 <25.0.0"
	},
	"packageManager": "bun@1.3.14",
	"scripts": {
		"build": "bunx tsc",
		"db:generate": "bunx drizzle-kit generate",
		"db:migrate": "bun ../scripts/migrate.ts",
		"db:migrate:baseline": "bun ../scripts/migrate.ts --baseline",
		"db:migrate:status": "bun ../scripts/migrate.ts --status",
		"db:push": "bunx drizzle-kit push",
		"db:seed": "bun src/db/seed.ts",
		"db:studio": "bunx drizzle-kit studio",
		"dev": "bun --watch src/app.ts",
		"lint": "bunx eslint src --report-unused-disable-directives --max-warnings 0",
		"lint:fix": "bunx eslint src --report-unused-disable-directives --max-warnings 0 --fix",
		"start": "bun src/app.ts",
		"stop": "bun run --cwd .. stop:backend",
		"typecheck": "bunx tsc",
		"preinstall": "only-allow bun"
	},
	"type": "module"
}
