				},
				"jwtRefreshPrivateKey": {
					"minLength": 16,
					"type": "string"
				},
				"jwtRefreshPrivateKeyPrevious": {
					"type": "string"
				},
				"jwtRefreshPublicKey": {
					"minLength": 16,
					"type": "string"
				},
				"jwtRefreshPublicKeyPrevious": {
					"type": "string"
				},
				"maxTokenSize": {
					"maximum": 9007199254740991,
					"minimum": -9007199254740991,
					"type": "integer"
				},
				"mfaChallengeExpiresIn": {
					"default": "5m",
					"type": "string"
				},
				"mfaPrivateKey": {
					"default": "",
					"description": "Dedicated ES256 private key for short-lived MFA challenge tokens. Generate with `bun run generate-keys`; required in production.",
