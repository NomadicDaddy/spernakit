{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"additionalProperties": false,
	"description": "Configuration schema for Spernakit v3 applications. Generated from backend Zod schemas via \"bun run config:schema\".",
	"properties": {
		"alerting": {
			"additionalProperties": false,
			"properties": {
				"cooldownMinutes": {
					"maximum": 9007199254740991,
					"minimum": 1,
					"type": "integer"
				},
				"email": {
					"additionalProperties": false,
					"properties": {
						"enabled": {
							"default": false,
							"type": "boolean"
						},
						"recipients": {
							"default": [],
							"items": {
								"format": "email",
								"pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$",
								"type": "string"
							},
							"type": "array"
						}
					},
					"required": ["enabled", "recipients"],
					"type": "object"
				},
				"inApp": {
					"additionalProperties": false,
					"properties": {
						"enabled": {
							"default": true,
							"type": "boolean"
						}
					},
					"required": ["enabled"],
					"type": "object"
				},
				"webhook": {
					"additionalProperties": false,
					"properties": {
						"enabled": {
							"default": false,
							"type": "boolean"
						},
						"headers": {
							"additionalProperties": {
								"type": "string"
							},
							"default": {},
							"propertyNames": {
								"type": "string"
							},
							"type": "object"
						},
						"secret": {
							"default": "",
							"type": "string"
						},
						"timeoutMs": {
							"maximum": 9007199254740991,
							"minimum": -9007199254740991,
							"type": "integer"
						},
						"url": {
							"anyOf": [
								{
									"format": "uri",
									"type": "string"
								},
								{
									"const": "",
									"type": "string"
								}
							],
							"default": ""
						}
					},
					"required": ["enabled", "headers", "secret", "timeoutMs", "url"],
					"type": "object"
				}
			},
			"required": ["cooldownMinutes", "email", "inApp", "webhook"],
			"type": "object"
		},
		"apiKeys": {
			"additionalProperties": false,
			"properties": {
				"maxPerUser": {
					"default": 10,
					"maximum": 9007199254740991,
					"minimum": 1,
					"type": "integer"
				}
			},
			"required": ["maxPerUser"],
			"type": "object"
		},
		"app": {
			"additionalProperties": false,
			"properties": {
				"description": {
					"type": "string"
				},
				"name": {
					"type": "string"
				},
				"slug": {
					"type": "string"
				}
			},
			"required": ["description", "name", "slug"],
			"type": "object"
		},
		"audit": {
			"additionalProperties": false,
			"properties": {
				"enabled": {
					"default": true,
					"type": "boolean"
				},
				"ipWhitelist": {
					"default": [],
					"items": {
						"type": "string"
					},
					"type": "array"
				}
			},
			"required": ["enabled", "ipWhitelist"],
			"type": "object"
		},
		"cors": {
			"additionalProperties": false,
			"properties": {
				"allowNoOrigin": {
					"default": false,
					"type": "boolean"
				},
				"allowedOrigins": {
					"default": [],
					"description": "Explicit list of allowed origins for production deployments with trustProxy enabled",
					"items": {
						"pattern": "^https?:\\/\\/[a-zA-Z0-9._-]+(:\\d+)?$",
						"type": "string"
					},
					"type": "array"
				},
				"frontendDevOrigins": {
					"default": [],
					"items": {
						"type": "string"
					},
					"type": "array"
				},
				"inheritFrontendUrl": {
					"default": false,
					"description": "When true and allowedOrigins is empty, server.frontendUrl is appended at config-load. Lets staging configs run in NODE_ENV=production without manually duplicating the host into cors.allowedOrigins. Off by default — real production should set allowedOrigins explicitly.",
					"type": "boolean"
				}
			},
			"required": [
				"allowedOrigins",
				"allowNoOrigin",
				"frontendDevOrigins",
				"inheritFrontendUrl"
			],
			"type": "object"
		},
		"dashboards": {
			"additionalProperties": false,
			"properties": {
				"enabled": {
					"default": true,
					"type": "boolean"
				},
				"maxPerUser": {
					"maximum": 9007199254740991,
					"minimum": 1,
					"type": "integer"
				},
				"sharingEnabled": {
					"type": "boolean"
				}
			},
			"required": ["enabled", "maxPerUser", "sharingEnabled"],
			"type": "object"
		},
		"database": {
			"additionalProperties": false,
			"properties": {
				"allowDbPush": {
					"default": false,
					"type": "boolean"
				},
				"backup": {
					"additionalProperties": false,
					"properties": {
						"compress": {
							"default": false,
							"type": "boolean"
						},
						"enabled": {
							"default": true,
							"type": "boolean"
						},
						"encrypt": {
							"default": true,
							"type": "boolean"
						},
						"intervalHours": {
							"maximum": 9007199254740991,
							"minimum": 1,
							"type": "integer"
						},
						"location": {
							"default": "./backups",
							"type": "string"
						},
						"retentionDays": {
							"maximum": 9007199254740991,
							"minimum": 1,
							"type": "integer"
						}
					},
					"required": [
						"compress",
						"enabled",
						"encrypt",
						"intervalHours",
						"location",
						"retentionDays"
					],
					"type": "object"
				},
				"busyTimeoutMs": {
					"default": 5000,
					"maximum": 9007199254740991,
					"minimum": 0,
					"type": "integer"
				},
				"dialect": {
					"default": "sqlite",
					"enum": ["sqlite", "postgres"],
					"type": "string"
				},
				"integrityCheck": {
					"additionalProperties": false,
					"properties": {
						"enabled": {
							"default": true,
							"type": "boolean"
						},
						"intervalHours": {
							"maximum": 9007199254740991,
							"minimum": 1,
							"type": "integer"
						},
						"mode": {
							"default": "quick",
							"enum": ["quick", "full"],
							"type": "string"
						}
					},
					"required": ["enabled", "intervalHours", "mode"],
					"type": "object"
				},
				"ssl": {
					"additionalProperties": false,
					"properties": {
						"enabled": {
							"default": false,
							"type": "boolean"
						},
						"rejectUnauthorized": {
							"default": true,
							"type": "boolean"
						}
					},
					"required": ["enabled", "rejectUnauthorized"],
					"type": "object"
				},
				"url": {
					"type": "string"
				},
				"vacuum": {
					"additionalProperties": false,
					"properties": {
						"enabled": {
							"default": true,
							"type": "boolean"
						},
						"intervalHours": {
							"maximum": 9007199254740991,
							"minimum": 1,
							"type": "integer"
						}
					},
					"required": ["enabled", "intervalHours"],
					"type": "object"
				}
			},
			"required": [
				"allowDbPush",
				"backup",
				"busyTimeoutMs",
				"dialect",
				"integrityCheck",
				"ssl",
				"url",
				"vacuum"
			],
			"type": "object"
		},
		"databaseAdmin": {
			"additionalProperties": false,
			"properties": {
				"enabled": {
					"default": false,
					"type": "boolean"
				}
			},
			"required": ["enabled"],
			"type": "object"
		},
		"email": {
			"additionalProperties": false,
			"properties": {
				"retryAttempts": {
					"default": 2,
					"maximum": 10,
					"minimum": 1,
					"type": "integer"
				},
				"retryDelayMs": {
					"default": 1000,
					"maximum": 60000,
					"minimum": 0,
					"type": "integer"
				}
			},
			"required": ["retryAttempts", "retryDelayMs"],
			"type": "object"
		},
		"healthCheck": {
			"additionalProperties": false,
			"properties": {
				"enabled": {
					"default": true,
					"type": "boolean"
				},
				"interval": {
					"maximum": 9007199254740991,
					"minimum": -9007199254740991,
					"type": "integer"
				},
				"retentionDays": {
					"maximum": 9007199254740991,
					"minimum": -9007199254740991,
					"type": "integer"
				},
				"thresholds": {
					"additionalProperties": false,
					"properties": {
						"auth": {
							"additionalProperties": false,
							"properties": {
								"critical": {
									"type": "number"
								},
								"warn": {
									"type": "number"
								}
							},
							"required": ["critical", "warn"],
							"type": "object"
						},
						"db": {
							"additionalProperties": false,
							"properties": {
								"critical": {
									"type": "number"
								},
								"warn": {
									"type": "number"
								}
							},
							"required": ["critical", "warn"],
							"type": "object"
						},
						"fs": {
							"additionalProperties": false,
							"properties": {
								"critical": {
									"type": "number"
								},
								"warn": {
									"type": "number"
								}
							},
							"required": ["critical", "warn"],
							"type": "object"
						},
						"memory": {
							"additionalProperties": false,
							"properties": {
								"critical": {
									"type": "number"
								},
								"warn": {
									"type": "number"
								}
							},
							"required": ["critical", "warn"],
							"type": "object"
						}
					},
					"required": ["auth", "db", "fs", "memory"],
					"type": "object"
				}
			},
			"required": ["enabled", "interval", "retentionDays", "thresholds"],
			"type": "object"
		},
		"logging": {
			"additionalProperties": false,
			"properties": {
				"file": {
					"additionalProperties": false,
					"default": {
						"enabled": false,
						"maxFiles": 10,
						"maxSize": "10M",
						"path": "./logs/app.log"
					},
					"properties": {
						"enabled": {
							"default": false,
							"type": "boolean"
						},
						"maxFiles": {
							"default": 10,
							"exclusiveMinimum": 0,
							"maximum": 9007199254740991,
							"type": "integer"
						},
						"maxSize": {
							"default": "10M",
							"type": "string"
						},
						"path": {
							"default": "./logs/app.log",
							"type": "string"
						}
					},
					"required": ["enabled", "maxFiles", "maxSize", "path"],
					"type": "object"
				},
				"level": {
					"default": "info",
					"enum": ["debug", "info", "warn", "error"],
					"type": "string"
				}
			},
			"required": ["file", "level"],
			"type": "object"
		},
		"metrics": {
			"additionalProperties": false,
			"properties": {
				"collectionIntervalMs": {
					"maximum": 9007199254740991,
					"minimum": -9007199254740991,
					"type": "integer"
				}
			},
			"required": ["collectionIntervalMs"],
			"type": "object"
		},
		"oauth": {
			"additionalProperties": false,
			"properties": {
				"github": {
					"additionalProperties": false,
					"properties": {
						"callbackUrl": {
							"default": "",
							"type": "string"
						},
						"clientId": {
							"default": "",
							"type": "string"
						},
						"clientSecret": {
							"default": "",
							"type": "string"
						},
						"enabled": {
							"default": false,
							"type": "boolean"
						}
					},
					"required": ["callbackUrl", "clientId", "clientSecret", "enabled"],
					"type": "object"
				},
				"google": {
					"additionalProperties": false,
					"properties": {
						"callbackUrl": {
							"default": "",
							"type": "string"
						},
						"clientId": {
							"default": "",
							"type": "string"
						},
						"clientSecret": {
							"default": "",
							"type": "string"
						},
						"enabled": {
							"default": false,
							"type": "boolean"
						}
					},
					"required": ["callbackUrl", "clientId", "clientSecret", "enabled"],
					"type": "object"
				},
				"microsoft": {
					"additionalProperties": false,
					"properties": {
						"callbackUrl": {
							"default": "",
							"type": "string"
						},
						"clientId": {
							"default": "",
							"type": "string"
						},
						"clientSecret": {
							"default": "",
							"type": "string"
						},
						"enabled": {
							"default": false,
							"type": "boolean"
						},
						"tenantId": {
							"default": "common",
							"type": "string"
						}
					},
					"required": ["callbackUrl", "clientId", "clientSecret", "enabled", "tenantId"],
					"type": "object"
				}
			},
			"required": ["github", "google", "microsoft"],
			"type": "object"
		},
		"rateLimit": {
			"additionalProperties": false,
			"properties": {
				"authEnabled": {
					"default": true,
					"type": "boolean"
				},
				"backend": {
					"enum": ["memory", "database"],
					"type": "string"
				},
				"enabled": {
					"default": true,
					"type": "boolean"
				},
				"maxRequests": {
					"maximum": 9007199254740991,
					"minimum": -9007199254740991,
					"type": "integer"
				},
				"windowMs": {
					"maximum": 9007199254740991,
					"minimum": -9007199254740991,
					"type": "integer"
				}
			},
			"required": ["authEnabled", "backend", "enabled", "maxRequests", "windowMs"],
			"type": "object"
		},
		"retention": {
			"additionalProperties": false,
			"properties": {
				"auditLogsDays": {
					"maximum": 9007199254740991,
					"minimum": 1,
					"type": "integer"
				},
				"businessEventsDays": {
					"maximum": 9007199254740991,
					"minimum": 1,
					"type": "integer"
				},
				"healthCheckAlertsDays": {
					"maximum": 9007199254740991,
					"minimum": 1,
					"type": "integer"
				},
				"healthCheckLogsDays": {
					"maximum": 9007199254740991,
					"minimum": 1,
					"type": "integer"
				},
				"notificationsDays": {
					"maximum": 9007199254740991,
					"minimum": 1,
					"type": "integer"
				},
				"scheduledTaskExecutionsDays": {
					"maximum": 9007199254740991,
					"minimum": 1,
					"type": "integer"
				},
				"softDeletedFilesDays": {
					"maximum": 9007199254740991,
					"minimum": 1,
					"type": "integer"
				},
				"systemMetricsDays": {
					"maximum": 9007199254740991,
					"minimum": 1,
					"type": "integer"
				}
			},
			"required": [
				"auditLogsDays",
				"businessEventsDays",
				"healthCheckAlertsDays",
				"healthCheckLogsDays",
				"notificationsDays",
				"scheduledTaskExecutionsDays",
				"softDeletedFilesDays",
				"systemMetricsDays"
			],
			"type": "object"
		},
		"roles": {
			"additionalProperties": false,
			"properties": {
				"ADMIN": {
