					"type": "string"
				},
				"oauthStateSecret": {
					"minLength": 32,
					"type": "string"
				},
				"passwordResetTokenExpiryMs": {
					"maximum": 86400000,
					"minimum": 300000,
					"type": "integer"
				},
				"refreshCookieName": {
					"type": "string"
				},
				"strictCsp": {
					"default": true,
					"type": "boolean"
				}
			},
			"required": [
				"applicationApiKey",
				"authCookieName",
				"backupEncryptionKey",
				"bcryptRounds",
				"cookieMaxAge",
