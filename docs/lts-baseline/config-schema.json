				},
				"authCookieName": {
					"type": "string"
				},
				"backupEncryptionKey": {
					"minLength": 64,
					"type": "string"
				},
				"backupEncryptionKeyPrevious": {
					"type": "string"
				},
				"bcryptRounds": {
					"default": 12,
					"maximum": 31,
					"minimum": 10,
					"type": "integer"
				},
				"cookieMaxAge": {
					"maximum": 9007199254740991,
					"minimum": -9007199254740991,
					"type": "integer"
				},
				"cookieSecret": {
					"minLength": 32,
					"type": "string"
				},
				"cookieSecure": {
					"default": true,
					"type": "boolean"
				},
				"crossOriginEmbedderPolicy": {
