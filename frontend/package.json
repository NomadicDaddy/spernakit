	"scripts": {
		"build": "bunx tsc -p tsconfig.build.json && bunx vite build",
		"dev": "bunx vite --host",
		"stop": "bun run --cwd .. stop:frontend",
		"lint": "bunx eslint . --report-unused-disable-directives --max-warnings 0",
		"lint:fix": "bunx eslint . --report-unused-disable-directives --max-warnings 0 --fix",
		"build:analyze": "ANALYZE=true bunx vite build",
		"typecheck": "bunx tsc -p tsconfig.build.json",
		"preinstall": "only-allow bun"
	},
	"type": "module"
