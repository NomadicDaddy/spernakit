{
	"name": "spernakit",
	"version": "3.28.2",
	"private": true,
	"author": "NomadicDaddy",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/NomadicDaddy/spernakit/issues"
	},
	"description": "Self-Hosted Multi-User Application Template",
	"keywords": [
		"bun",
		"drizzle-orm",
		"elysia",
		"full-stack",
		"react",
		"self-hosted",
		"shadcn-ui",
		"sqlite",
		"tanstack-query",
		"template",
		"typescript",
		"vite"
	],
	"devDependencies": {
		"@eslint/js": "10.0.1",
		"@types/bun": "1.3.14",
		"eslint": "10.7.0",
		"eslint-plugin-jsdoc": "63.2.0",
		"eslint-plugin-perfectionist": "5.10.0",
		"eslint-plugin-react-hooks": "7.1.1",
		"eslint-plugin-react-refresh": "0.5.3",
		"eslint-plugin-unused-imports": "4.4.1",
		"globals": "17.7.0",
		"knip": "6.27.0",
		"prettier": "3.9.6",
		"prettier-plugin-organize-attributes": "1.0.0",
		"prettier-plugin-sort-json": "4.2.0",
		"prettier-plugin-tailwindcss": "0.8.1",
		"puppeteer": "25.3.0",
		"rotating-file-stream": "3.2.9",
		"typescript": "6.0.3",
		"typescript-eslint": "8.65.0"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"homepage": "https://github.com/NomadicDaddy/spernakit#readme",
	"packageManager": "bun@1.3.14",
	"repository": {
		"type": "git",
		"url": "https://github.com/NomadicDaddy/spernakit.git"
	},
	"scripts": {
		"build": "bun run build:backend && bun run build:frontend",
		"build:backend": "bun run --cwd backend build",
		"build:frontend": "bun run --cwd frontend build",
		"check-application": "bun scripts/check-application.ts",
		"check-auth-reset-api": "bun scripts/test-auth-reset-api.ts",
		"check-lockout-refresh": "bun scripts/test-lockout-refresh-decouple.ts",
		"check-auth-reset-ui-dev": "bun scripts/test-auth-reset-ui.ts --mode dev",
		"check-auth-reset-ui-preview": "bun scripts/test-auth-reset-ui.ts --mode preview",
		"check:api-types": "bun scripts/validate-api-types.ts",
		"check:config": "bun scripts/check-config-invariants.ts",
		"check:critical-path": "bun scripts/check-critical-path.ts",
		"check-deps": "bun scripts/check-dependency-versions.ts",
		"check:db-location": "bun scripts/check-db-location.ts",
		"check:dead-code": "bunx knip",
		"check-docs": "bun scripts/check-docs.ts",
		"check:drift": "bun scripts/check-template-drift.ts",
		"check:fleet-manifest": "bun scripts/check-fleet-manifest.ts",
		"check:leak-guard": "bash scripts/check-leak-guard.sh",
		"check:license-core": "bun scripts/check-license-core.ts",
		"check:licenses": "bun run check:license-core && bun scripts/generate-third-party-licenses.ts --check",
		"check:max-lines": "bun scripts/check-max-lines.ts",
		"check:no-inline-references": "bun scripts/check-no-inline-references.ts",
		"check:feature-integration": "bun scripts/check-feature-integration.ts",
		"check:fresh-release": "bun scripts/check-fresh-release.ts",
		"check:image-publication": "bun scripts/check-image-publication.ts",
		"check:schema-drift": "bun scripts/check-config-schema-drift.ts",
		"check:schema-parity": "bun scripts/check-schema-parity.ts",
		"check:secrets-shape": "bun scripts/check-secrets-shape.ts",
		"check:process-env": "bun scripts/check-process-env.ts",
		"check:destructive-confirmation": "bun scripts/check-destructive-confirmation.ts",
		"config:schema": "bun scripts/generate-config-schema.ts && bunx prettier --write --log-level warn config/config-schema.json",
		"config:validate": "bun scripts/validate-config.ts",
		"crawltest": "bun scripts/crawltest.ts --mode dev && bun scripts/crawltest-analyze.ts",
		"crawltest:analyze": "bun scripts/crawltest-analyze.ts",
		"crawltest:preview": "bun scripts/crawltest.ts --mode preview && bun scripts/crawltest-analyze.ts",
		"db:generate": "bun run --cwd backend db:generate",
		"db:migrate": "bun run --cwd backend db:migrate",
		"db:migrate:baseline": "bun run --cwd backend db:migrate:baseline",
		"db:migrate:status": "bun run --cwd backend db:migrate:status",
		"db:setup": "bun run --cwd backend db:migrate && bun run --cwd backend db:seed",
		"deploy:local-prod": "bun scripts/deploy-local-prod.ts",
		"docker:build": "docker compose build",
		"docker:down": "docker compose down",
		"docker:down:test": "docker compose -f docker-compose.yml -f docker-compose.test.yml down",
		"docker:image:build": "bun scripts/docker-image.ts build",
		"docker:up": "docker compose up -d",
		"docker:up:test": "docker compose -f docker-compose.yml -f docker-compose.test.yml up -d --build",
		"dev": "bun run check-application && bun run stop && bun scripts/dev-with-logs.ts",
		"dev:backend": "bun run check-application && bun run --cwd backend dev",
		"dev:frontend": "bun run --cwd frontend dev",
		"dev:quick": "bun run check-application && bun run stop && bun run --parallel dev:backend dev:frontend",
		"format": "bunx prettier --write .",
		"format:check": "bunx prettier --check .",
		"generate-keys": "bun scripts/generate-keys.ts",
		"lint": "bun run --cwd shared lint && bun run --cwd backend lint && bun run --cwd frontend lint && bun run lint:scripts",
		"lint:fix": "bun run --cwd shared lint:fix && bun run --cwd backend lint:fix && bun run --cwd frontend lint:fix && bun run lint:scripts:fix",
		"lint:scripts": "bunx eslint scripts --report-unused-disable-directives --max-warnings 0",
		"lint:scripts:fix": "bunx eslint scripts --report-unused-disable-directives --max-warnings 0 --fix",
		"licenses:generate": "bun scripts/generate-third-party-licenses.ts",
		"licenses:image": "bun scripts/check-image-licenses.ts --update",
		"licenses:sync-core": "bun scripts/sync-license-core.ts",
		"licenses:sync-core:check": "bun scripts/sync-license-core.ts --check",
		"check:image-licenses": "bun scripts/check-image-licenses.ts",
		"optimize-images": "bun scripts/optimize-images.ts",
		"optimize-images:dry-run": "bun scripts/optimize-images.ts --dry-run",
		"optimize-images:force": "bun scripts/optimize-images.ts --force",
		"prepare": "(git config core.hooksPath .githooks && bash .githooks/leak-guard-setup.sh) || true",
		"profile:cpu": "bun --cpu-prof-md run --cwd backend start",
		"profile:heap": "bun --heap-prof-md run --cwd backend start",
		"qc:fix": "bun run lint:fix && bun run format && bun run smoke:qc",
		"qc:status": "bun scripts/smoke.ts --mode qc --cache-status",
		"release:notes": "bun scripts/release-notes.ts",
		"reset-packages": "bun scripts/reset-packages.ts",
		"setup": "bun scripts/setup.ts",
		"smoke:dev": "bun scripts/smoke.ts --mode dev",
		"smoke:docker-local": "bun scripts/smoke.ts --mode docker-local",
		"smoke:docker-prod": "bun scripts/smoke.ts --mode docker-prod",
		"smoke:preview": "bun scripts/smoke.ts --mode preview",
		"smoke:qc": "bun scripts/smoke.ts --mode qc",
		"smoke:qc:fast": "bun scripts/smoke.ts --mode qc --fast",
		"smoke:reset": "bun scripts/smoke.ts --mode reset",
		"smoke:screenshots": "bun scripts/smoke.ts --mode screenshots",
		"smoke:cycle": "bun run stop && bun -e \"import{readdirSync,unlinkSync}from'node:fs';readdirSync('logs').filter(f=>f.endsWith('.log')).forEach(f=>unlinkSync('logs/'+f))\" && bun run start && bun -e \"await new Promise(r=>setTimeout(r,10000))\" && bun run stop",
		"start": "bun scripts/start.ts --check",
		"stop": "bun scripts/stop.ts",
		"stop:backend": "bun scripts/stop.ts --backend",
		"stop:frontend": "bun scripts/stop.ts --frontend",
		"supertest": "bun run smoke:reset && bun run smoke:docker-prod && bun run smoke:screenshots",
		"template:sync-plan": "bun scripts/template-sync-plan.ts",
		"test:fresh-release": "bun scripts/test-fresh-release.ts",
		"typecheck": "bun run --cwd shared typecheck && bun run --cwd backend typecheck && bun run --cwd frontend typecheck && bunx tsc --project scripts/tsconfig.json",
		"verify-mutation-denylist": "bun scripts/verify-mutation-denylist.ts",
		"verify-compression": "bun scripts/verify-compression.ts",
		"verify-minification": "bun scripts/verify-minification.ts",
		"preinstall": "bun scripts/require-bun.ts",
		"smoke:docs": "bun scripts/sync-smoke-docs.ts",
		"check:smoke-docs": "bun scripts/sync-smoke-docs.ts --check"
	},
	"type": "module",
	"workspaces": [
		"backend",
		"frontend",
		"shared"
	],
	"overrides": {
		"@radix-ui/react-dialog": "1.1.20",
		"esbuild": "0.25.12"
	}
}
