#!/usr/bin/env bash
# Thin wrapper: the guard owns the logic, this owns only the wiring.
#
# git passes the remote name/URL as $1/$2 and the ref updates on stdin. Both are forwarded.
#
# If a repository grows its own pre-push checks, chain them here rather than replacing this file —
# core.hooksPath allows exactly one pre-push, so an overwrite silently disables the guard.
set -euo pipefail

hooks_dir="$(dirname "$0")"

echo "pre-push: aidd history guard"
bash "$hooks_dir/aidd-history-guard.sh" "${1:-origin}"

echo "pre-push: passed"
